FAL_KEY=your_fal_key_here
FAL_IMAGE_ENDPOINT=fal-ai/nano-banana-2
FAL_IMAGE_EDIT_ENDPOINT=fal-ai/nano-banana-2/edit

# Brand analysis (畫面風格 → 品牌風格分析) — same key as HarmoniqFengShui
DEEPSEEK_API_KEY=your_deepseek_key_here
# Use deepseek-chat (cheap, non-thinking). Avoid deepseek-reasoner for this app — ~8× output cost.
# DEEPSEEK_MODEL=deepseek-chat

# Optional — Step 4 post-process (subtitles / dub) only
OPENAI_API_KEY=your_openai_key_here

# Live platform content research (Step 1 + assistant) — need ONE of these:
# TAVILY_API_KEY=tvly-...   # https://tavily.com (free tier)
# SERPER_API_KEY=...        # https://serper.dev (Google results)

# Xiaohongshu note search with cover images + engagement (recommended for HK/CN)
# See docs/XHS_NOTE_SEARCH_SETUP.md
# JUSTONEAPI_TOKEN=your_justoneapi_token_here
# JUSTONEAPI_BASE_URL=https://api.justoneapi.com
# Optional China endpoint: JUSTONEAPI_BASE_URL=http://47.117.133.51:30015
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_REWRITE_MODEL=gpt-4.1-mini
# Voiceover TTS — defaults to fal MiniMax (uses FAL_KEY). Set TTS_PROVIDER=azure to use Azure instead.
# FAL_TTS_ENDPOINT=fal-ai/minimax/speech-2.8-turbo
# FAL_TTS_ENDPOINT=fal-ai/minimax/speech-2.8-hd
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=your_azure_region_here

# Optional — future AI assistant (Phase 2)
# OPENAI_API_KEY is reused for guided chat

# Clerk auth (HK — Development keys until you have a custom domain)
# After sign-in/up: SignInButton uses the page URL the user was on (query preserved).
# These URLs apply when Clerk has no return URL (e.g. direct /sign-in visit):
REGION=hk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/start
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/start
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — error monitoring (Sentry). Leave unset to disable.
# NEXT_PUBLIC_SENTRY_DSN=https://...@....ingest.sentry.io/...
# Optional: SENTRY_AUTH_TOKEN for source map uploads in CI

# MongoDB Atlas — required in production (project autosave). Optional in local dev.
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/alchemy?retryWrites=true&w=majority

# Optional — Playwright E2E (dedicated Clerk test user with password auth)
# E2E_CLERK_USER_EMAIL=test@example.com
# E2E_CLERK_USER_PASSWORD=your_test_password
# E2E_CLERK_USER_ID=user_...
