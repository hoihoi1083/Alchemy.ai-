{
  "name": "alchemy-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "setup:bgm": "bash scripts/setup-bgm.sh",
    "setup:compositor": "bash scripts/setup-compositor-fonts.sh",
    "render:career-carousel": "npx tsx scripts/render-career-carousel.ts",
    "render:career-realistic": "npx tsx scripts/render-career-carousel-realistic.ts",
    "render:career-photo": "npx tsx scripts/render-career-carousel-photo.ts",
    "generate:comic-journey": "npx tsx scripts/generate-comic-journey.ts",
    "refix:comic-captions": "npx tsx scripts/refix-comic-captions.ts",
    "generate:watercolor-journey": "npx tsx scripts/generate-watercolor-journey.ts",
    "generate:journey-unified": "npx tsx scripts/generate-journey-unified.ts",
    "layout:journey-unified": "npx tsx scripts/generate-journey-unified.ts -- --layout-only",
    "generate:journey-watercolor": "npx tsx scripts/generate-journey-watercolor.ts",
    "layout:journey-watercolor": "npx tsx scripts/generate-journey-watercolor.ts -- --layout-only",
    "recompose:journey-watercolor": "npx tsx scripts/generate-journey-watercolor.ts -- --text-only",
    "render:life-path": "npx tsx scripts/render-life-path-carousel.ts",
    "cleanup:pipeline-jobs": "node scripts/cleanup-pipeline-jobs.mjs",
    "test:coach": "npx tsx scripts/test-studio-assistant-coach.ts",
    "test:mobile-layout": "npx tsx scripts/audit-mobile-layout.ts",
    "test:conversation": "npx tsx scripts/test-studio-assistant-conversation.ts",
    "test": "tsx scripts/test-all.ts",
    "test:unit": "tsx --test tests/*.test.ts",
    "test:live": "tsx scripts/test-all.ts --live",
    "test:live:quick": "tsx scripts/test-all.ts --live --quick",
    "test:generate": "tsx scripts/test-generate-pipeline-smoke.ts",
    "test:pipeline": "tsx scripts/test-pipeline-smoke.ts",
    "test:pipeline:full": "SMOKE_T2V=1 tsx scripts/test-pipeline-smoke.ts",
    "test:projects": "tsx scripts/test-projects-crud.ts",
    "test:full": "tsx scripts/test-all.ts --live --generate",
    "test:integration": "tsx scripts/test-integration-env.ts",
    "test:integration:live": "tsx scripts/test-integration-env.ts --live",
    "test:justone-mp4": "tsx scripts/test-justone-mp4-pipeline.ts",
    "test:assistant": "npx tsx scripts/test-studio-assistant-coach.ts && npx tsx scripts/test-studio-assistant-routing-matrix.ts && npx tsx scripts/test-studio-assistant-conversation.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "setup:secrets": "tsx scripts/setup-prod-secrets.ts",
    "setup:sentry-alert": "tsx scripts/setup-sentry-alert.ts"
  },
  "dependencies": {
    "@clerk/localizations": "^4.9.3",
    "@clerk/nextjs": "^7.5.8",
    "@fal-ai/client": "^1.4.0",
    "@sentry/nextjs": "^10.63.0",
    "@xyflow/react": "^12.6.0",
    "jsonrepair": "^3.14.1",
    "mongodb": "^7.3.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@clerk/testing": "^2.2.2",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.7.0"
  }
}
